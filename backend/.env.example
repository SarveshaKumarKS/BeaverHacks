GEMINI_API_KEY=
NVIDIA_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
NVIDIA_NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
# Silent Orchestrator referee — routes the conversation state machine
NVIDIA_ORCHESTRATOR_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
FRONTEND_ORIGIN=http://localhost:3000

# Optional: set to enable provider TTS at POST /tts (uses OpenAI voices)
# Without this, the frontend falls back to browser speechSynthesis
OPENAI_API_KEY=

